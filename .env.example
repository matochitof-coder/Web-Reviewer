# Required by the API server at runtime

# Set to "production" in Railway
NODE_ENV=production

# Railway sets PORT automatically — do NOT set it manually in Railway variables
# PORT=8080

# Clash of Clans developer portal credentials (developer.clashofclans.com)
# The server uses these to auto-generate an API key tied to its current IP.
# Required for the Mi Clan page to load clan members.
COC_DEV_EMAIL=tu_email@ejemplo.com
COC_DEV_PASSWORD=tu_contraseña
